APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ===========================================
# Party Planner Configuration
# ===========================================

# Currency
CURRENCY_CODE=XAF
CURRENCY_SYMBOL=FCFA

# Subscription Plans Pricing
PLAN_STARTER_PRICE=5000
PLAN_STARTER_GUESTS=50
PLAN_STARTER_EXTRA_GUEST_PRICE=50
PLAN_STARTER_MAX_COLLABORATORS=2

PLAN_PRO_PRICE=15000
PLAN_PRO_GUESTS=200
PLAN_PRO_EXTRA_GUEST_PRICE=30

# Free Tier Limits
FREE_TIER_MAX_GUESTS=10
FREE_TIER_MAX_COLLABORATORS=1
FREE_TIER_MAX_EVENTS=1
FREE_TIER_MAX_PHOTOS=5

# File Uploads
PHOTO_MAX_SIZE=5120
PHOTO_MAX_PER_UPLOAD=10
CSV_MAX_SIZE=2048

# Budget Alerts
BUDGET_ALERT_THRESHOLD=90

# ===========================================
# MTN Mobile Money Configuration (using lepresk/momo-api)
# ===========================================
#
# --- SANDBOX (tests) ---
# 1. Créer un compte sur https://momodeveloper.mtn.com
# 2. S'abonner au produit "Collection" (gratuit)
# 3. Dans votre profil, récupérer la Subscription Key (Primary)
# 4. Créer un API User (UUID auto-généré) + générer son API Key
# 5. Mettre MTN_ENVIRONMENT=sandbox et MTN_SIMULATE=false (ou true pour simuler sans réseau)
# 6. Numéros de test : 46733123450 (succès), 46733123451 (échec), 46733123452 (timeout)
#
# --- PRODUCTION (Congo-Brazzaville) ---
# 1. Contacter MTN Congo : sosclient.cg@mtn.com / WhatsApp 067000123
# 2. Soumettre dossier KYC (entreprise)
# 3. MTN crée un compte sur https://momoapi.mtn.com avec votre email
# 4. Connexion via OTP → Profile → API Access → Create API User
#    → Renseigner providerCallbackHost (HTTPS obligatoire)
#    → Copier API User + API Key affichés UNE SEULE FOIS
# 5. Récupérer Primary Key et Secondary Key dans la section Profile
# 6. Mettre MTN_ENVIRONMENT=mtncongo, MTN_SIMULATE=false, MTN_HTTP_VERIFY_SSL=true
# 7. MTN_CALLBACK_URL doit être en HTTPS (ex: https://api.yourdomain.com/momo/callback)
#
MTN_ENABLED=false
MTN_SIMULATE=false

# Credentials — fournis par MTN (production) ou auto-générés (sandbox)
MTN_API_USER=
MTN_API_KEY=
# Primary Key = clé principale utilisée dans Ocp-Apim-Subscription-Key
MTN_SUBSCRIPTION_KEY=
# Secondary Key = clé de secours fournie par MTN (même produit, backup)
MTN_SUBSCRIPTION_KEY_SECONDARY=

# URL de callback MTN — DOIT être HTTPS en production
# Route disponible : https://votre-domaine.com/momo/callback
MTN_CALLBACK_URL="${APP_URL}/momo/callback"

# Secret HMAC pour valider la signature des callbacks entrants (header X-Callback-Signature)
# Définir une valeur forte (min 32 chars) — OBLIGATOIRE en production
MTN_WEBHOOK_SECRET=

# Environnement : sandbox | mtncongo | mtncameroon | mtnuganda | mtnghana | mtnivorycoast …
MTN_ENVIRONMENT=sandbox

# Devise : EUR pour sandbox, XAF pour Congo/Cameroun en production
MTN_CURRENCY=XAF

# HTTP Client
MTN_HTTP_TIMEOUT=30
MTN_HTTP_VERIFY_SSL=true

# ===========================================
# Airtel Money Configuration
# ===========================================
# To enable: 1) Create account at developers.airtel.africa
#            2) Create an application (sandbox)
#            3) Get Client ID and Client Secret
AIRTEL_ENABLED=false
AIRTEL_API_URL=https://openapi.airtel.africa
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
AIRTEL_CALLBACK_URL="${APP_URL}/api/webhooks/airtel"
AIRTEL_ENVIRONMENT=sandbox
AIRTEL_WEBHOOK_SECRET=

# ===========================================
# Stripe Configuration
# ===========================================
STRIPE_KEY=pk_test_your_publishable_key
STRIPE_SECRET=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ===========================================
# Twilio Configuration (SMS & WhatsApp)
# ===========================================
TWILIO_SID=your_twilio_account_sid
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_FROM=+242xxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886

# ===========================================
# Firebase Cloud Messaging Configuration
# ===========================================
FIREBASE_CREDENTIALS=storage/app/firebase-credentials.json
# You can also use individual credentials:
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ===========================================
# AWS S3 Configuration
# ===========================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=your-bucket-name
AWS_USE_PATH_STYLE_ENDPOINT=false

# CloudFront CDN URL for assets (photos, images). If set, generated URLs use this domain instead of S3 direct.
# Example: https://d3blwjb0y2g3mz.cloudfront.net
CDN_URL=

# ===========================================
# Webhook URLs (for external services)
# ===========================================
# Configure these URLs in your payment/messaging provider dashboards:
# Stripe: ${APP_URL}/webhooks/stripe
# MTN: ${APP_URL}/webhooks/mtn or ${APP_URL}/momo/callback (see MTN_CALLBACK_URL)
# Airtel: ${APP_URL}/webhooks/airtel
# Twilio SMS Status: ${APP_URL}/webhooks/twilio/sms/status
# Twilio SMS Incoming: ${APP_URL}/webhooks/twilio/sms/incoming
# Twilio WhatsApp Status: ${APP_URL}/webhooks/twilio/whatsapp/status
# Twilio WhatsApp Incoming: ${APP_URL}/webhooks/twilio/whatsapp/incoming
